/* inventory.wxss */
.container {
  padding: 20rpx;
  background-color: #f7eee3; /* 白玉色 */
  min-height: 100vh;
}

.header {
  padding: 20rpx 0;
  margin-bottom: 20rpx;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #1f1f1f; /* 漆黑色 */
}

.subtitle {
  font-size: 24rpx;
  color: #1f1f1f; /* 漆黑色 */
  margin-top: 10rpx;
}

/* 库存列表样式 */
.inventory-list {
  margin-bottom: 20rpx;
}

.inventory-item {
  background-color: #f7eee3; /* 白玉色 */
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 2rpx 10rpx rgba(31, 31, 31, 0.1); /* 漆黑色透明阴影 */
  position: relative; /* 为加载指示器提供定位上下文 */
}

.product-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 8rpx;
  margin-right: 20rpx;
  background-color: #f7eee3; /* 漆黑色 */
}

.product-info {
  flex: 1;
}

.product-name {
  font-size: 30rpx;
  font-weight: 500;
  display: block;
  margin-bottom: 8rpx;
  color: #1f1f1f; /* 漆黑色 */
}

.product-code {
  font-size: 24rpx;
  color: #1f1f1f; /* 漆黑色 */
  display: block;
  margin-bottom: 8rpx;
}

.inventory-status {
  display: flex;
  justify-content: space-between;
  flex-wrap: wrap;
  margin-bottom: 4rpx;
}

.inventory-quantity {
  font-size: 26rpx;
  color: #1f1f1f; /* 漆黑色 */
}

.inventory-price {
  font-size: 26rpx;
  color: #ff5f00; /* 黄丹色 */
  font-weight: 500;
}

.inventory-date {
  font-size: 24rpx;
  color: #1f1f1f; /* 漆黑色 */
}

/* 盘点操作样式 */
.check-list {
  margin-bottom: 20rpx;
}

.check-item {
  background-color: #f7eee3; /* 白玉色 */
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 2rpx 10rpx rgba(31, 31, 31, 0.1); /* 漆黑色透明阴影 */
  position: relative; /* 为加载指示器提供定位上下文 */
}

.quantity-control {
  display: flex;
  align-items: center;
  margin-left: 20rpx;
}

.decrease,
.increase {
  width: 60rpx;
  height: 60rpx;
  background-color: #ff5f00; /* 黄丹色 */
  color: white;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  font-size: 40rpx;
  font-weight: bold;
}

.decrease {
  margin-right: 20rpx;
}

.increase {
  margin-left: 20rpx;
}

.quantity-input {
  width: 80rpx;
  height: 60rpx;
  background-color: white;
  text-align: center;
  border-radius: 8rpx;
}

/* 按钮样式 */
.action-bar {
  padding: 20rpx 0;
  display: flex;
  justify-content: space-between;
}

.check-button,
.export-button,
.cancel-button,
.submit-button {
  flex: 1;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 500;
  border-radius: 8rpx;
  margin: 0 10rpx;
}

.check-button {
  background-color: #ff5f00; /* 黄丹色 */
  color: white;
}

.export-button {
  background-color: #1f1f1f; /* 漆黑色 */
  color: white;
}

.cancel-button {
  background-color: #1f1f1f; /* 漆黑色 */
  color: white;
}

.submit-button {
  background-color: #ff5f00; /* 黄丹色 */
  color: white;
}

/* 加载中样式 */
.loading-container {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: rgba(255, 255, 255, 0.6);
  z-index: 100;
}

.loading {
  width: 80rpx;
  height: 80rpx;
  background-color: #ff5f00; /* 黄丹色 */
  border-radius: 50%;
  animation: pulse 1s infinite ease-in-out;
}

@keyframes pulse {
  0% {
    transform: scale(0.8);
    opacity: 0.8;
  }
  50% {
    transform: scale(1.2);
    opacity: 1;
  }
  100% {
    transform: scale(0.8);
    opacity: 0.8;
  }
}

/* 图片加载指示器 */
.image-loading-indicator {
  position: absolute;
  top: 20rpx;
  left: 20rpx;
  width: 120rpx;
  height: 120rpx;
  background-color: rgba(31, 31, 31, 0.1);
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.image-loading-indicator:after {
  content: "";
  position: absolute;
  width: 200%;
  height: 200%;
  background: linear-gradient(
    90deg,
    rgba(255, 255, 255, 0) 0%,
    rgba(255, 255, 255, 0.3) 50%,
    rgba(255, 255, 255, 0) 100%
  );
  animation: loading-shimmer 1.5s infinite;
  transform: skewX(-20deg);
}

@keyframes loading-shimmer {
  0% {
    transform: translateX(-100%) skewX(-20deg);
  }
  100% {
    transform: translateX(100%) skewX(-20deg);
  }
}
