/**app.wxss**/
page {
  background-color: #f7eee3; /* 白玉色 */
  font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", Helvetica,
    "Segoe UI", Arial, Roboto, "PingFang SC", "miui", "Hiragino Sans GB",
    "Microsoft Yahei", sans-serif;
  font-size: 14px;
  color: #1f1f1f; /* 漆黑色 */
  box-sizing: border-box;
  height: 100%;
}

.container {
  min-height: 100%;
  padding: 20rpx;
  box-sizing: border-box;
}

/* 通用按钮样式 */
.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx 30rpx;
  font-size: 28rpx;
  border-radius: 8rpx;
  text-align: center;
}

.btn-primary {
  background-color: #ff5f00; /* 黄丹色 */
  color: #f7eee3; /* 白玉色 */
}

.btn-default {
  background-color: #f7eee3; /* 白玉色 */
  color: #1f1f1f; /* 漆黑色 */
}

/* 通用表单样式 */
.form-group {
  margin-bottom: 30rpx;
}

.form-label {
  display: block;
  margin-bottom: 10rpx;
  font-size: 28rpx;
  color: #1f1f1f; /* 漆黑色 */
}

.form-control {
  width: 100%;
  height: 80rpx;
  padding: 0 20rpx;
  border: 1rpx solid #1f1f1f; /* 漆黑色 */
  border-radius: 8rpx;
  box-sizing: border-box;
  font-size: 28rpx;
}

/* 加载动画 */
.loading-container {
  display: flex;
  justify-content: center;
  padding: 40rpx 0;
}

.loading {
  width: 80rpx;
  height: 80rpx;
  background-color: #ff5f00; /* 黄丹色 */
  border-radius: 50%;
  animation: pulse 1s infinite ease-in-out;
}

@keyframes pulse {
  0% {
    transform: scale(0.8);
    opacity: 0.8;
  }
  50% {
    transform: scale(1.2);
    opacity: 1;
  }
  100% {
    transform: scale(0.8);
    opacity: 0.8;
  }
}

/* 无数据提示 */
.no-data {
  text-align: center;
  padding: 100rpx 0;
  color: #1f1f1f; /* 漆黑色 */
}

.no-data-icon {
  font-size: 120rpx;
  margin-bottom: 20rpx;
}

/* 卡片样式 */
.card {
  background-color: #f7eee3; /* 白玉色 */
  border-radius: 8rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

/* 列表样式 */
.list {
  background-color: #f7eee3; /* 白玉色 */
  border-radius: 8rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
}

.list-item {
  padding: 30rpx;
  border-bottom: 1rpx solid #1f1f1f; /* 漆黑色 */
}

.list-item:last-child {
  border-bottom: none;
}
