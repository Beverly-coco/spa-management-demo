<!--pages/login/login.wxml-->
<view class="container">
  <view class="logo-container">
    <image class="logo" src="/assets/images/logo.png" mode="aspectFit" style="width: 249rpx; height: 231rpx; display: block; box-sizing: border-box; position: relative; left: 1rpx; top: 20rpx"></image>
    <text class="title">方壶SPA管理系统</text>
    <text class="subtitle">门店端</text>
  </view>
  
  <view class="login-form">
    <view class="form-group">
      <text class="form-label">门店编号</text>
      <input class="form-input" type="text" placeholder="请输入门店编号" value="{{storeCode}}" bindinput="inputStoreCode" />
    </view>
    
    <view class="error-message" wx:if="{{error}}">
      <text>{{error}}</text>
    </view>
    
    <button class="login-button" bindtap="handleLogin" loading="{{loading}}" disabled="{{loading}}">登录</button>
    
    <view class="tips">
      <text>提示：请输入您的门店编号（如：S001）</text>
    </view>
  </view>
  
  <view class="footer">
    <text>© 2025 成都星睿棱镜科技有限公司</text>
  </view>
</view> 