/* pages/login/login.wxss */
.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  min-height: 100vh;
  padding: 40rpx;
  box-sizing: border-box;
  background-color: #f7eee3; /* 白玉色 */
}

.logo-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 30rpx;
  margin-bottom: 20rpx;
}

.logo {
  width: 180rpx;
  height: 180rpx;
  margin-bottom: 20rpx;
}

.title {
  font-size: 40rpx;
  font-weight: bold;
  color: #1f1f1f; /* 漆黑色 */
  margin-bottom: 6rpx;
}

.subtitle {
  font-size: 28rpx;
  color: #1f1f1f; /* 漆黑色 */
}

.login-form {
  width: 100%;
  margin-top: 20rpx;
}

.form-group {
  margin-bottom: 25rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: #1f1f1f; /* 漆黑色 */
  margin-bottom: 8rpx;
}

.form-input {
  width: 100%;
  height: 90rpx;
  background-color: #f7eee3; /* 白玉色 */
  border-radius: 8rpx;
  padding: 0 20rpx;
  box-sizing: border-box;
  font-size: 32rpx;
  border: 1px solid #1f1f1f; /* 漆黑色 */
}

.error-message {
  color: #ff5f00; /* 黄丹色 */
  font-size: 24rpx;
  margin-bottom: 15rpx;
}

.login-button {
  width: 100%;
  height: 90rpx;
  background-color: #ff5f00; /* 黄丹色 */
  color: #f7eee3; /* 白玉色 */
  border-radius: 8rpx;
  font-size: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 15rpx;
}

.tips {
  text-align: center;
  font-size: 24rpx;
  color: #1f1f1f; /* 漆黑色 */
  margin-top: 15rpx;
}

.footer {
  font-size: 24rpx;
  color: #1f1f1f; /* 漆黑色 */
  margin-top: auto;
  padding-top: 30rpx;
  text-align: center;
}
