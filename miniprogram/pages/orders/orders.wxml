<!--pages/orders/orders.wxml-->
<view class="container">
  <!-- 页面标题 -->
  <view class="page-header">
    <view class="page-title">采购订单</view>
    <view class="header-actions">
      <button class="create-btn" bindtap="createOrder">新建订单</button>
    </view>
  </view>

  <!-- 筛选栏 -->
  <view class="filter-bar">
    <view class="filter-item">
      <picker bindchange="onStatusChange" value="{{statusIndex}}" range="{{statusOptions}}">
        <view class="picker">
          {{statusOptions[statusIndex]}}
        </view>
      </picker>
    </view>
    <view class="filter-item">
      <picker mode="date" fields="month" bindchange="onMonthChange">
        <view class="picker">
          {{selectedMonth || '选择月份'}}
        </view>
      </picker>
    </view>
  </view>

  <!-- 订单列表 -->
  <view class="order-list" wx:if="{{!loading}}">
    <view class="order-item" wx:for="{{orders}}" wx:key="id" bindtap="viewOrderDetail" data-id="{{item.id}}">
      <view class="order-header">
        <view class="order-number">订单号：{{item.orderNumber}}</view>
        <view class="order-status {{item.status}}">{{item.statusText}}</view>
      </view>
      <view class="order-info">
        <view class="order-date">创建时间：{{item.createdAt}}</view>
        <view class="order-total">总金额：¥{{item.totalAmount}}</view>
      </view>
      <view class="order-items">
        <view class="item-count">{{item.itemCount}}个商品</view>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{!loading && orders.length === 0}}">
    <view class="empty-icon">📋</view>
    <view class="empty-text">暂无订单</view>
    <button class="create-btn" bindtap="createOrder">创建第一个订单</button>
  </view>

  <!-- 加载状态 -->
  <view class="loading-container" wx:if="{{loading}}">
    <view class="loading"></view>
  </view>
</view>